# Build artifacts
docs/results/*.log
docs/results/tmp/

# Exclude source copies from git to reduce repo size
docs/results/*/source/
docs/results/*/*/source/
docs/results/*/*/*/source/

# Source packages (cloned at runtime, not committed)
sources/*/
!sources/README.md

# Python
__pycache__/
*.pyc
.venv/

# Local model config file
models.yaml

# Editor files
*.swp
*~

.assets
*.obsinfo
*.obscpio
*.osc
_build.*
_service:*
.pbuild
