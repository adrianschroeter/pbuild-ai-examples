+Name:           cl-local-time
+Version:        1.0.6
+Release:        0
+Summary:        A Common Lisp library for manipulating dates and times
+License:        MIT
+URL:            https://github.com/dlowe-net/local-time
+Source0:        https://github.com/dlowe-net/local-time/archive/refs/tags/v1.0.6.tar.gz
+BuildArch:      noarch
+BuildRequires:  cl-asdf
+BuildRequires:  common-lisp-controller
+
+%description
+CL-LOCAL-TIME is a Common Lisp library for manipulating dates and times,
+based on Erik Naggum's paper "The Long Painful History of Time". It provides
+time zones with DST handling, interval arithmetic, timezone data, date-time
+to string formatting, and various conversion utilities.
+
+%prep
+%autosetup -p1 -n local-time-%{version}
+
+%build
+# Lisp libraries are typically source-only; no compilation needed
+
+%install
+mkdir -p %{buildroot}%{_datadir}/common-lisp/source/%{name}/
+cp -r * %{buildroot}%{_datadir}/common-lisp/source/%{name}/
+mkdir -p %{buildroot}%{_datadir}/common-lisp/systems/
+if [ -f %{buildroot}%{_datadir}/common-lisp/source/%{name}/%{name}.asd ]; then
+  ln -sf ../source/%{name}/%{name}.asd %{buildroot}%{_datadir}/common-lisp/systems/%{name}.asd
+fi
+
+%post
+register-common-lisp-implementation sbcl
+
+%preun
+unregister-common-lisp-implementation sbcl
+
+%files
+%license COPYING
+%doc CREDITS INSTALL README TODO doc/
+%dir %{_datadir}/common-lisp/source/%{name}/
+%{_datadir}/common-lisp/source/%{name}/
+%{_datadir}/common-lisp/systems/%{name}.asd
+
+%changelog
