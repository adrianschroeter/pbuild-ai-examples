+Name:           local-time
+Version:        1.0~6
+Release:        0
+Summary:        Common Lisp library for manipulating dates and times
+License:        MIT
+URL:            https://github.com/dlowe-net/local-time
+Source:         https://github.com/dlowe-net/local-time/archive/refs/tags/v%{version}.tar.gz#/v1.0.6.tar.gz
+
+BuildArch:      noarch
+Group:          Development/Libraries/Other
+BuildRequires:  cl-asdf
+BuildRequires:  common-lisp-controller
+
+%description
+The LOCAL-TIME library is a Common Lisp library for the manipulation of
+dates and times. It is based almost entirely upon Erik Naggum's paper
+"The Long Painful History of Time".
+
+This package provides timezone data files alongside the library.
+
+%prep
+%autosetup -n %{name}-1.0~6
+
+# Remove upstream .gitignore to avoid conflicts with RPM's own handling
+rm -f .gitignore
+
+%build
+# Lisp libraries are typically source-only; no compilation needed
+
+%install
+mkdir -p %{buildroot}%{_datadir}/common-lisp/source/%{name}
+cp -r src/%{name}.lisp \
+      src/package.lisp \
+      cl-postgres+local-time.asd \
+      local-time.asd \
+      local-time.test.asd \
+      README \
+      TODO \
+      CREDITS \
+      INSTALL \
+      COPYING \
+      %{buildroot}%{_datadir}/common-lisp/source/%{name}/
+
+mkdir -p %{buildroot}%{_datadir}/common-lisp/systems
+ln -sf ../source/%{name}/local-time.asd \
+       %{buildroot}%{_datadir}/common-lisp/systems/local-time.asd
+ln -sf ../source/%{name}/local-time.test.asd \
+       %{buildroot}%{_datadir}/common-lisp/systems/local-time-test.asd
+
+mkdir -p %{buildroot}%{_datadir}/zoneinfo
+cp -a zoneinfo/* %{buildroot}%{_datadir}/zoneinfo/
+
+%post
+register-common-lisp-implementation clisp
+
+%preun
+unregister-common-lisp-implementation clisp
+
+%files
+%license COPYING
+%doc README TODO CREDITS INSTALL
+%dir %{_datadir}/common-lisp/source/%{name}
+%{_datadir}/common-lisp/source/%{name}
+%{_datadir}/common-lisp/systems/local-time.asd
+%{_datadir}/common-lisp/systems/local-time-test.asd
+%{_datadir}/zoneinfo
+
+%changelog
