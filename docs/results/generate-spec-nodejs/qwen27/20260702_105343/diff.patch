+Name:           npm-chalk
+Version:        5.3.0
+Release:        0
+Summary:        Terminal string styling done right
+License:        MIT
+URL:            https://github.com/chalk/chalk
+Source0:        https://registry.npmjs.org/chalk/-/chalk-%{version}.tgz
+
+BuildArch:      noarch
+
+BuildRequires:  nodejs
+Requires:       nodejs
+
+%description
+Chalk is terminal string styling done right, with support for
+nesting, chaining and dynamic styler creation. All features work on
+all text colors (not just ANSI 16 colors).
+
+%prep
+%autosetup -n package -p1
+
+%build
+# No build step required for JS modules
+
+%install
+mkdir -p %{buildroot}%{_datadir}/nodejs/%{name}
+cp -a source %{buildroot}%{_datadir}/nodejs/%{name}/
+chmod 644 %{buildroot}%{_datadir}/nodejs/%{name}/source/*.{js,d.ts}
+chmod -R 755 %{buildroot}%{_datadir}/nodejs/%{name}/source/vendor/
+mkdir -p %{buildroot}%{_datadir}/licenses/%{name}
+cp -a license README.md %{buildroot}%{_datadir}/licenses/%{name}/
+
+%files
+%doc README.md
+%dir %{_datadir}/licenses/%{name}
+%{_datadir}/licenses/%{name}/*
+%dir %{_datadir}/nodejs/%{name}
+%{_datadir}/nodejs/%{name}/source/*
+
+%changelog
