+# SPDX-FileCopyrightText: 2024 openSUSE developers <opensuse-packaging@opensuse.org>
+# SPDX-License-Identifier: FSFAP
+
+Name:           golang-github-com-spf13-cobra
+Version:        1.8.0
+Release:        0
+Summary:        A library for creating powerful modern CLI applications
+License:        Apache-2.0
+Url:            https://github.com/spf13/cobra
+Source:         https://github.com/spf13/cobra/archive/refs/tags/v%{version}.tar.gz
+BuildRequires:  golang-github-com-cpuguy83-go-md2man-v2
+BuildRequires:  golang-github-com-inconshreveable-mousetrap
+BuildRequires:  golang-github-com-spf13-pflag
+BuildRequires:  golang-gopkg.in-yaml-v3
+BuildArch:      noarch
+
+%description
+Cobra is a library providing a simple interface to create powerful modern
+CLI-like applications. It is used in many Go projects such as Kubernetes,
+Hugo, and GitHub CLI.
+
+%prep
+%autosetup -n cobra-%{version}
+
+%build
+# No build step needed for pure source installation
+
+%install
+export GOPATH=%{_builddir}/go
+mkdir -p $GOPATH/src/github.com/spf13/cobra
+cp -a . $GOPATH/src/github.com/spf13/cobra/
+
+mkdir -p %{buildroot}%{gopathdir}/src/github.com/spf13/
+cp -a $GOPATH/src/github.com/spf13/cobra/* %{buildroot}%{gopathdir}/src/github.com/spf13/cobra/
+
+%files
+%{gopathdir}/src/github.com/spf13/cobra
