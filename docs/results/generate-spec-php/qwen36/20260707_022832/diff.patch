+Name:           phpstan
+Version:        1.10.0
+Release:        0
+Summary:        PHPStan - PHP Static Analysis Tool
+License:        MIT
+URL:            https://phpstan.org/
+Source:         https://github.com/phpstan/phpstan/archive/refs/tags/1.10.0.tar.gz
+BuildRequires:  php >= 5.6
+BuildArch:      noarch
+
+%description
+PHPStan focuses on finding errors in your code without actually running it.
+It catches whole classes of bugs even before you write tests for the code.
+It moves PHP closer to compiled languages in the sense that the correctness
+of each line of the code can be checked before you run the actual line.
+
+%install
+install -Dm644 phpstan-%{version}/phpstan.phar %{buildroot}%{_datadir}/phpstan/phpstan.phar
+install -d -m755 %{buildroot}%{_datadir}/phpstan/conf
+cat > phpstan-wrapper <<'EOF'
+#!/usr/bin/env php
+<?php
+
+declare (strict_types=1);
+
+Phar::loadPhar(__DIR__ . '/../share/phpstan/phpstan.phar', 'phpstan.phar');
+
+require 'phar://phpstan.phar/bin/phpstan';
+EOF
+install -Dm755 phpstan-wrapper %{buildroot}%{_bindir}/phpstan
+
+%files
+%license phpstan-%{version}/LICENSE
+%doc phpstan-%{version}/README.md
+%dir %{_datadir}/phpstan/
+%{_datadir}/phpstan/*.phar
+%{_datadir}/phpstan/conf/
+%{_bindir}/phpstan
+
+%changelog
