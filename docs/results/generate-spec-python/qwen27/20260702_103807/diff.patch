+# SPDX-FileCopyrightText: 2024 Ollama <hello@ollama.com>
+# SPDX-License-Identifier: MIT
+Name:           python-ollama
+Version:        0.3.3
+Release:        0
+Summary:        The official Python client for Ollama
+License:        MIT
+Group:          Development/Libraries/Python
+Url:            https://github.com/ollama/ollama-python
+Source0:        https://pypi.io/packages/source/o/ollama/ollama-0.3.3.tar.gz
+BuildArch:      noarch
+
+%description
+The Ollama Python library provides the easiest way to integrate Python 3.8+ projects with Ollama.
+
+%prep
+%autosetup -p1
+
+%build
+# No compilation needed for pure Python
+
+%install
+# Install the package using pip
+%python_install --root=$RPM_BUILD_ROOT --prefix=%{_prefix}
+
+# Run fdupes on installed files to hardlink duplicates
+%fdupes $RPM_BUILD_ROOT%{_prefix}
+
+%check
+# Run tests (if any) - skip if pytest is not available
+%if 0%{?with_tests}
+PYTHONPATH=$RPM_BUILD_ROOT%{python3_sitelib} \
+pytest --ignore=examples -v
+%endif
+
+%files %{py_files_standard_requirements}
+%doc README.md LICENSE
+
+%changelog
