 # It will be fixed in the next release
 Patch3:         fix-bsdunzip-test.patch
+# PATCH-FIX-SUSU CVE security fix from upstream
+# RAR4 LZSS bounds check for copy_from_lzss_window_to_unp
+Patch4:         fix-rar-bounds-check.patch
 BuildRequires:  cmake
