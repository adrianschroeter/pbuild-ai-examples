+Name:           font-roboto
+Version:        2.138
+Release:        0
+Summary:        Clean and friendly sans serif font by Google
+License:        Apache-2.0
+URL:            https://github.com/googlefonts/roboto-2
+Source:         https://github.com/googlefonts/roboto-2/releases/download/v2.138/roboto-unhinted.zip
+BuildRequires:  fdupes
+BuildRequires:  fontpackages-backend-afm
+Requires:       fontpackages >= 0.6
+BuildArch:      noarch
+
+%description
+Roboto is a clean, friendly sans serif font designed for Roboto by Google.
+This package contains the unhinted TrueType fonts (regular, italic, bold,
+bold italic, black, black italic, light, light italic, medium, medium
+italic, thin, and thin italic) in both regular and condensed variants.
+
+%prep
+%setup -q -n roboto-unhinted
+
+%build
+
+%install
+for font in *.ttf; do
+  mkdir -p %{buildroot}%{_fontdir}/roboto
+  install -m 644 "$font" %{buildroot}%{_fontdir}/roboto/
+done
+# Install LICENSE file
+mkdir -p %{buildroot}%{_docdir}/%{name}
+install -m 644 LICENSE %{buildroot}%{_docdir}/%{name}/
+
+%post
+fontcache_post
+
+%postun
+fontcache_postun
+
+%files
+%defattr(-, root, root)
+%dir %{_fontdir}/roboto
+%{_fontdir}/roboto/*.ttf
+%doc %{_docdir}/%{name}
+
+%changelog
