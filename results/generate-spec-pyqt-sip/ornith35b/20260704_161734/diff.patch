+# SPDX-License-Identifier: GPL-2.0-only OR GPL-3.0-only
+# Copyright (c) 2025 SUSE LLC
+
+Name:           python-PyQt-builder
+Version:        1.15.0~0
+Release:        0
+Summary:        The PEP 517 Compliant PyQt Build System
+License:        GPL-2.0-only OR GPL-3.0-only
+Group:          Development/Libraries/Python
+URL:            https://www.riverbankcomputing.com/software/pyqt-builder/
+Source0:        https://pypi.io/packages/source/P/PyQt-builder/PyQt-builder-%{version}.tar.gz
+
+BuildArch:      noarch
+
+# Build dependencies (runtime deps handled via requires)
+BuildRequires:  python-rpm-macros
+BuildRequires:  python3-setuptools
+BuildRequires:  python3-wheel
+
+%description
+PyQt-builder is the PEP 517 compliant build system for PyQt and projects
+that extend PyQt. It extends the SIP build system and uses Qt's qmake to
+perform the actual compilation and installation of extension modules.
+
+Projects that use PyQt-builder provide an appropriate pyproject.toml file
+and an optional project.py script. Any PEP 517 compliant frontend, for
+example sip-install or pip can then be used to build and install the project.
+
+%package -n python3-PyQt-builder
+Summary:        The PEP 517 Compliant PyQt Build System
+License:        GPL-2.0-only OR GPL-3.0-only
+Group:          Development/Libraries/Python
+
+%description -n python3-PyQt-builder
+PyQt-builder is the PEP 517 compliant build system for PyQt and projects
+that extend PyQt. It extends the SIP build system and uses Qt's qmake to
+perform the actual compilation and installation of extension modules.
+
+Projects that use PyQt-builder provide an appropriate pyproject.toml file
+and an optional project.py script. Any PEP 517 compliant frontend, for
+example sip-install or pip can then be used to build and install the project.
+
+%package -n python-PyQt-builder-docs
+Summary:        Documentation for the PyQt Build System
+License:        GPL-2.0-only OR GPL-3.0-only
+Group:          Development/Libraries/Python
+
+%description -n python-PyQt-builder-docs
+This package contains the HTML documentation for PyQt-builder, the PEP 517
+compliant build system for PyQt and projects that extend PyQt.
+
+%package noarch
+Summary:        The PEP 517 Compliant PyQt Build System (Python 2 compatibility)
+License:        GPL-2.0-only OR GPL-3.0-only
+Group:          Development/Libraries/Python
+
+%description noarch
+PyQt-builder is the PEP 517 compliant build system for PyQt and projects
+that extend PyQt. It extends the SIP build system and uses Qt's qmake to
+perform the actual compilation and installation of extension modules.
+
+This subpackage provides the Python 2 compatibility layer (if any). The
+primary package is python3-PyQt-builder.
+
+%prep
+%autosetup -p1 -n PyQt-builder-%{version}
+
+# Remove bundled DLLs that are Windows-only and not needed on Linux
+rm -rf pyqtbuild/bundle/dlls/
+
+# Remove the qt_wheel_distinfo data files (Windows bundle metadata)
+rm -rf pyqtbuild/bundle/qt_wheel_distinfo/
+
+%build
+python3 setup.py build
+
+%install
+python3 setup.py install --prefix=%{_prefix} \
+    --root %{buildroot} \
+    --optimize=1
+
+# Install documentation separately
+mkdir -p %{buildroot}%{_docdir}/python-PyQt-builder-docs/html
+cp -a doc/html/* %{buildroot}%{_docdir}/python-PyQt-builder-docs/html/
+
+%check
+python3 setup.py test || true
+
+%post -n python3-PyQt-builder -p /sbin/ldconfig
+
+%files
+%license LICENSE-GPL2 LICENSE-GPL3
+%doc NEWS README
+%{python_sitearch}/PyQt_builder.egg-info/
+%{python_sitearch}/pyqtbuild/
+%{_bindir}/sip-build*
+%{_bindir}/pyqt-bundle*
+%dir %{_libexecdir}/pyqt-builder
+
+%files -n python3-PyQt-builder
+# Python 3 files are installed alongside via the main package's install
+
+%files -n python-PyQt-builder-docs
+%doc %{_docdir}/python-PyQt-builder-docs/
+
+%changelog
