-Hi,
-
-A certain user faced bug of sub builtin function and report to me.
-Then I investigated the bug.
-
-reproduce script is here.
-
-BEGIN {
-	str = "type=\"directory\" version=\"1.0\""
-	#print "BEGIN:", str
-
-	while (str) {
-		sub(/^[^=]*/, "", str);
-		s = substr(str, 2)
-		print s
-		sub(/^="[^"]*"/, "", str)
-		sub(/^[ \t]*/, "", str)
-	}
-}
