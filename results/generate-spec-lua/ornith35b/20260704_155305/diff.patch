+Name:           lua51-luafilesystem
+Version:        1.8.0
+Release:        0
+Summary:        Lua File System Library
+License:        MIT
+Group:          Development/Libraries/Other
+URL:            https://keplerproject.github.io/luafilesystem
+Source0:        https://github.com/lunarmodules/luafilesystem/archive/v1_8_0.tar.gz
+
+BuildRequires:  lua51-devel
+BuildRequires:  pkgconf-pkg-config
+
+%description
+LuaFileSystem is a Lua library developed to complement the set of functions
+related to file systems offered by the standard Lua distribution. It offers
+a portable way to access the underlying directory structure and file attributes.
+
+%package -n     lua51-luafilesystem-doc
+Summary:        Documentation for Lua FileSystem
+Group:          Documentation/Other
+BuildArch:      noarch
+
+%description -n lua51-luafilesystem-doc
+Documentation files for the LuaFileSystem package.
+
+%prep
+%autosetup -p1 -n luafilesystem-%{version}
+
+# Patch config file to use proper paths
+sed -i 's|PREFIX=/usr/local|PREFIX=%{_prefix}|' config
+sed -i 's|-I/usr/include/lua$(LUA_VERSION)|-I%{_includedir}/lua$(LUA_VERSION)|' config
+sed -i 's|-I/usr/include/lua/$(LUA_VERSION)||' config
+
+# Override LUA_LIBDIR to use proper Lua architecture directory
+echo "LUA_LIBDIR= $(PREFIX)/lib/lua/\$(LUA_VERSION)" >> Makefile
+
+%build
+make CC="%{__cc}" \
+     CFLAGS="%{optflags} -fPIC" \
+     PREFIX=%{_prefix} \
+     LUA_VERSION=%{lua_version}
+
+%install
+mkdir -p %{buildroot}%{lua_archdir}
+make install DESTDIR=%{buildroot} PREFIX=%{_prefix} LUA_LIBDIR=%{buildroot}%{lua_archdir}/
+
+# Install documentation
+mkdir -p %{buildroot}%{_docdir}/%{name}
+cp -a doc/us/* %{buildroot}%{_docdir}/%{name}/
+cp LICENSE README.md %{buildroot}%{_docdir}/%{name}/
+
+# Set proper permissions on installed files
+find %{buildroot} -type f -exec chmod 644 {} +
+chmod 755 %{buildroot}%{lua_archdir}
+
+%files
+%license LICENSE
+%doc README.md
+%{lua_archdir}/lfs.so
+
+%files -n lua51-luafilesystem-doc
+%defattr(-, root, root)
+%{_docdir}/%{name}/
+%license LICENSE
+
+%changelog
