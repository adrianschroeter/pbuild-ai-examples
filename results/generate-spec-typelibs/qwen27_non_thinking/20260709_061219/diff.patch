+Name:           libpeas
+Version:        1.36.0
+Release:        0
+Summary:        GObject Plugins Engine Library
+License:        LGPL-2.1-or-later
+Group:          System/Libraries
+URL:            https://wiki.gnome.org/Projects/Libpeas
+Source0:        https://download.gnome.org/sources/libpeas/1.36/%{name}-%{version}.tar.xz
+#Maintainer: TODO
+BuildRequires:  fdupes
+BuildRequires:  gobject-introspection
+BuildRequires:  gtk-doc-tools
+BuildRequires:  gtk3-devel
+BuildRequires:  meson >= 0.50.0
+BuildRequires:  pkg-config
+BuildRequires:  python3-rpm-macros
+BuildRequires:  sed
+BuildRequires:  tar
+BuildRequires:  xz
+BuildRequires:  zip
+
+%description
+libpeas is a gobject-based plugins engine, and is targetted at giving every
+application the chance to assume its own extensibility. It is currently used by
+several Gnome applications like gedit and Totem.
+
+%package -n libpeas-1_0-0
+Summary:        GObject Plugins Engine Library
+Group:          System/Libraries
+License:        LGPL-2.1-or-later
+
+%description -n libpeas-1_0-0
+libpeas is a gobject-based plugins engine, and is targetted at giving every
+application the chance to assume its own extensibility. It is currently used by
+several Gnome applications like gedit and Totem.
+
+%package -n libpeas-gtk-1_0-0
+Summary:        GObject Plugins Engine Library for GTK+ 3
+Group:          System/Libraries
+License:        LGPL-2.1-or-later
+Requires:       libpeas-1_0-0 = %{version}
+
+%description -n libpeas-gtk-1_0-0
+This package contains the GTK+ 3 widgetry for libpeas, providing a plugin
+manager dialog and other UI components.
+
+%package -n libpeas-devel
+Summary:        GObject Plugins Engine Library -- Development Files
+Group:          Development/Libraries/GNOME
+License:        LGPL-2.1-or-later
+Requires:       gobject-introspection
+Requires:       gtk3-devel
+Requires:       libpeas-1_0-0 = %{version}
+
+%description -n libpeas-devel
+This package contains libraries and .spec files needed for writing
+applications that use libpeas.
+
+%package -n libpeas-gtk-devel
+Summary:        GObject Plugins Engine Library for GTK+ 3 -- Development Files
+Group:          Development/Libraries/GNOME
+License:        LGPL-2.1-or-later
+Requires:       libpeas-devel = %{version}
+Requires:       libpeas-gtk-1_0-0 = %{version}
+
+%description -n libpeas-gtk-devel
+This package contains libraries and .spec files needed for writing
+applications that use the GTK+ 3 widgetry of libpeas.
+
+%package -n typelib-1_0-Peas-1_0
+Summary:        GObject Introspection bindings for libpeas
+Group:          Development/Libraries/GNOME
+License:        LGPL-2.1-or-later
+
+%description -n typelib-1_0-Peas-1_0
+GObject Introspection bindings for the libpeas library.
+
+%package -n typelib-1_0-GtkPeas-1_0
+Summary:        GObject Introspection bindings for libpeas-gtk
+Group:          Development/Libraries/GNOME
+License:        LGPL-2.1-or-later
+
+%description -n typelib-1_0-GtkPeas-1_0
+GObject Introspection bindings for the GTK+ 3 widgetry of libpeas.
+
+%package -n python3-libpeas
+Summary:        Python3 loader module for libpeas
+Group:          Development/Libraries/GNOME
+License:        LGPL-2.1-or-later
+Requires:       libpeas-1_0-0 = %{version}
+%{python_requires_pkgconfig libpeas-1.0}
+
+%description -n python3-libpeas
+This package contains the Python3 loader module for libpeas, allowing
+plugins written in Python3 to be loaded by applications using libpeas.
+
+%prep
+%autosetup -p1
+
+%build
+%meson \
+  -Dgtk_doc=true \
+  -Dlua51_loader=false \
+  -Dpython2_loader=false \
+  -Dpython3_loader=true \
+  -Dglade_catalog=true \
+  -Ddemos=false
+%meson_build
+
+%install
+%meson_install
+%suse_update_desktop_file -r libpeas-peas-demo Application System
+%fdupes %{buildroot}
+%suse_replace_deps libpeas-gtk.pc
