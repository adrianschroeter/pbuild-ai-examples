+
+%files -n libpeas-gtk-devel
+%doc NEWS README
+
+%files -n typelib-1_0-Peas-1_0
+%{_libdir}/girepository-1.0/Peas-1.0.typelib
+
+%files -n typelib-1_0-GtkPeas-1_0
+%{_libdir}/girepository-1.0/GtkPeas-1.0.typelib
+
+%files -n python3-libpeas
