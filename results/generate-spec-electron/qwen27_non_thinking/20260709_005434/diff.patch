+#
+
+Name:           atom
+Version:        1.60.0
+Release:        0
+Summary:        A hackable text editor for the 21st Century
+License:        MIT
+URL:            https://atom.io
+Source0:        https://github.com/atom/atom/archive/refs/tags/v%{version}.tar.gz/%{name}-%{version}.tar.gz
+Source99:       %{name}.desktop
+Source100:      0001-disable-update-check.patch
+Source101:      0002-disable-telemetry.patch
+Source102:      0003-fix-resource-path.patch
+
+BuildRequires:  nodejs-electron-devel >= 9.0
+BuildRequires:  npm
+BuildRequires:  coffee-script
+BuildRequires:  less
+BuildRequires:  fdupes
+BuildRequires:  update-desktop-database
+
+Requires:       nodejs-electron%{_isa} >= 9.0
+Requires:       hicolor-icon-theme
+
+%description
+Atom is a text editor that is modern, approachable, and hackable to the
+core. It is designed for customizability while remaining approachable for
+all users. Built on Node.js and Electron, it combines clean, familiar UI
+design with the power of features like inline preview and fuzzy finding
+of files.
+
+%prep
+%autosetup -p1
+
+# Remove precompiled binaries to ensure they are rebuilt for the target architecture
+find . -name '*.node' -delete
+find . -name '*.jar' -delete
+find . -name '*.dll' -delete
+find . -name '*.exe' -delete
+find . -name '*.dylib' -delete
+find . -not -type d -name '*.so' -delete
+find . -name '*.o' -delete
+find . -name '*.a' -delete
+find . -name '*.wasm' -delete
+
+# Remove any existing node_modules that might cause issues
+rm -rf node_modules
+
+%build
+export ELECTRON_SKIP_BINARY_DOWNLOAD=1
+export ESBUILD_BINARY_PATH=""
+
+# Install dependencies without running scripts that might try to download things
+npm ci --ignore-scripts --no-optional
+
+# Rebuild native modules against system Electron
+%electron_rebuild
+
+# Transpile CoffeeScript files
+npx coffee -co src/ src/**/*.coffee
+
+# Compile LESS stylesheets
+npx lessc static/linux.less out/style.css
+
+%install
+# Create application directory in libdir
+mkdir -p %{buildroot}%{_libdir}/%{name}
+
+# Install the application source
+cp -a src node_modules packages static apm docs scripts \
+      atom.sh package.json LICENSE.md README.md \
+      %{buildroot}%{_libdir}/%{name}/
+
+# Create wrapper script for launching Atom
+cat > %{buildroot}%{_bindir}/atom << 'EOF'
+#!/bin/sh
+ATOM_RESOURCE_PATH="%{_libdir}/atom"
+export ATOM_RESOURCE_PATH
+exec nodejs-electron "$ATOM_RESOURCE_PATH/src/main-process/main.js" "$@"
+EOF
+chmod 755 %{buildroot}%{_bindir}/atom
+
+# Create wrapper script for APM (Atom Package Manager)
+cat > %{buildroot}%{_bindir}/apm << 'EOF'
+#!/bin/sh
+ATOM_RESOURCE_PATH="%{_libdir}/atom"
+export ATOM_RESOURCE_PATH
+exec node "$ATOM_RESOURCE_PATH/apm/node_modules/.bin/apm" "$@"
+EOF
+chmod 755 %{buildroot}%{_bindir}/apm
+
+# Install .desktop file
+install -D -m 644 %{SOURCE99} %{buildroot}%{_datadir}/applications/%{name}.desktop
+
+# Install application icons
+for size in 16 24 32 48 64 128 256 512; do
+    install -D -m 644 "resources/app-icons/stable/png/${size}.png" \
+        "%{buildroot}%{_datadir}/icons/hicolor/${size}x${size}/apps/%{name}.png"
+done
+
+# Deduplicate files
+%fdupes %{buildroot}%{_libdir}/%{name}
+
+%files
+%license LICENSE.md
+%doc README.md docs/
+%{_bindir}/atom
+%{_bindir}/apm
+%{_datadir}/applications/%{name}.desktop
+%{_datadir}/icons/hicolor/*/apps/%{name}.png
+%{_libdir}/%{name}
