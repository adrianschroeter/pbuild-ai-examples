+Name:           cl-local-time
+Version:        1.0.6
+Release:        0
+Summary:        Time Manipulation Library for Common Lisp
+License:        MIT
+Group:          Development/Libraries/Other
+URL:            http://common-lisp.net/project/local-time/
+Source0:        https://github.com/dlowe-net/local-time/archive/refs/tags/v%{version}.tar.gz
+
+BuildRequires:  cl-asdf
+BuildRequires:  common-lisp-controller
+BuildArch:      noarch
+
+%description
+local-time is a Common Lisp library for manipulating dates and times.
+It provides timestamp manipulation, timezone support with bundled zoneinfo,
+formatting and parsing of time strings, and various utility functions
+for working with calendar dates and times.
+
+%prep
+%autosetup -n local-time-%{version}
+
+%build
+# Lisp libraries are typically source-only; no compilation needed
+
+%install
+mkdir -p %{buildroot}%{_datadir}/common-lisp/source/%{name}/
+cp -r COPYING CREDITS INSTALL README TODO \
+       cl-postgres+local-time.asd local-time.asd src zoneinfo \
+       %{buildroot}%{_datadir}/common-lisp/source/%{name}/
+mkdir -p %{buildroot}%{_datadir}/common-lisp/systems/
+ln -sf ../source/%{name}/local-time.asd %{buildroot}%{_datadir}/common-lisp/systems/local-time.asd
+ln -sf ../source/%{name}/cl-postgres+local-time.asd %{buildroot}%{_datadir}/common-lisp/systems/cl-postgres+local-time.asd
+
+%post
+register-common-lisp-implementation clisp
+
+%preun
+unregister-common-lisp-implementation clisp
+
+%files
+%license COPYING
+%doc README INSTALL TODO CREDITS
+%dir %{_datadir}/common-lisp/source/%{name}/
+%{_datadir}/common-lisp/source/%{name}/
+%{_datadir}/common-lisp/systems/local-time.asd
+%{_datadir}/common-lisp/systems/cl-postgres+local-time.asd
+
+%changelog
