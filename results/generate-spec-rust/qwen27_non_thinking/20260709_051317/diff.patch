diff -Nur '--exclude=.git' '--exclude=_build.*' '--exclude=*.pyc' '--exclude=__pycache__' '--exclude=.pbuild' '--exclude=.pai.context' source_backup/_cargo_vendor.sh sources/rust-example/_cargo_vendor.sh
--- source_backup/_cargo_vendor.sh	1970-01-01 01:00:00.000000000 +0100
+++ sources/rust-example/_cargo_vendor.sh	2026-07-09 06:10:49.866056106 +0200
@@ -0,0 +1,12 @@
+#!/bin/sh
+set -e
+cd $(dirname $0)
+tar xzf cargo-*.tar.gz
+cd cargo-*
+cargo vendor --locked > Cargo.vendor
+tar czf ../registry.tar.gz vendor/
+gzip -d ../registry.tar.gz 2>/dev/null || true
+bsdtar --zst -cf ../registry.tar.zst -T - <(cat <<EOF
+vendor/
+EOF
+)
