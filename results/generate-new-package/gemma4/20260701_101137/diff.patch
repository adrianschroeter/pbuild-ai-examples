+Name:           ripgrep
+Version:        15.1.0
+Release:        0
+Summary:        A line-oriented search tool that recursively searches the current directory for a regex pattern
+License:        MIT
+Group:          Utilities/TextProcessing
+URL:            https://github.com/BurntSushi/ripgrep
+Source0:        https://github.com/BurntSushi/ripgrep/archive/refs/tags/%{version}.tar.gz
+
+BuildRequires:  cargo
+BuildRequires:  pcre2-devel
+BuildRequires:  rust
+
+%prep
+%autosetup -n ripgrep-%{version}
+
+%build
+export CARGO_HOME=%{_builddir}/cargo
+cargo build --release --features pcre2
+
+%install
+install -Dm755 target/release/rg %{buildroot}%{_bindir}/rg
+
+# Generate man page using the built binary
+target/release/rg --man > %{buildroot}%{_mandir}/man1/rg.1
+
+install -Dm644 COPYING %{buildroot}%{_docdir}/ripgrep/COPYING
+install -Dm644 LICENSE-MIT %{buildroot}%{_docdir}/ripgrep/LICENSE-MIT
+install -Dm644 UNLICENSE %{buildroot}%{_docdir}/ripgrep/UNLICENSE
+install -Dm644 README.md %{buildroot}%{_docdir}/ripgrep/README.md
+install -Dm644 FAQ.md %{buildroot}%{_docdir}/ripgrep/FAQ.md
+
+%files
+%defattr(-,root,root)
+%{_bindir}/rg
+%{_mandir}/man1/rg.1
+%{_docdir}/ripgrep/COPYING
+%{_docdir}/ripgrep/LICENSE-MIT
+%{_docdir}/ripgrep/UNLICENSE
+%{_docdir}/ripgrep/README.md
+%{_docdir}/ripgrep/FAQ.md
+
+%set_permissions
+%fdupes
+
+%changelog
