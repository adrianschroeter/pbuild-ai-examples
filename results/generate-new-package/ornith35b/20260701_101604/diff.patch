+
+Name:           ripgrep
+Version:        15.1.0
+Release:        0
+Summary:        Line-oriented search tool that recursively searches directories for a regex pattern
+License:        MIT OR Unlicense
+URL:            https://github.com/BurntSushi/ripgrep
+Source0:        https://github.com/BurntSushi/ripgrep/releases/download/%{version}/%{name}-%{version}-x86_64-unknown-linux-musl.tar.gz
+
+BuildRoot:      %{_tmppath}/%{name}-%{version}-build
+
+%description
+ripgrep (rg) is a line-oriented search tool that recursively searches your
+current directory for a regex pattern. By default, ripgrep will respect your
+.gitignore and automatically skip hidden files/directories and binary files.
+
+ripgrep is compatible with grep, ag, ack, and fd. It can be used as a drop-in
+replacement for most use cases of these tools.
+
+%prep
+# Nothing to do - source tarball contains pre-built binary and documentation
+
+%build
+# Nothing to do - using pre-built static binary
+
+%install
+mkdir -p %{buildroot}%{_bindir}
+mkdir -p %{buildroot}%{_mandir}/man1
+mkdir -p %{buildroot}%{_sysconfdir}/bash_completion.d
+mkdir -p %{buildroot}%{_datadir}/fish/vendor_completions.d
+mkdir -p %{buildroot}%{_datadir}/zsh/site-functions
+
+# Install the binary (rename to rgrep for distro compatibility)
+install -Dm755 rg %{buildroot}%{_bindir}/rgrep
+
+# Install documentation files
+install -Dm644 COPYING %{buildroot}%{_docdir}/%{name}/COPYING
+install -Dm644 LICENSE-MIT %{buildroot}%{_docdir}/%{name}/LICENSE-MIT
+install -Dm644 UNLICENSE %{buildroot}%{_docdir}/%{name}/UNLICENSE
+
+# Install changelog and README
+install -Dm644 CHANGELOG.md %{buildroot}%{_docdir}/%{name}/CHANGELOG
+install -Dm644 README.md %{buildroot}%{_docdir}/%{name}/README
+install -Dm644 FAQ.md %{buildroot}%{_docdir}/%{name}/FAQ
+
+# Install man page
+install -Dm644 rg.1 %{buildroot}%{_mandir}/man1/rgrep.1.gz
+
+# Install shell completions
+install -Dm644 rg.bash %{buildroot}%{_sysconfdir}/bash_completion.d/rgrep
+install -Dm644 rg.fish %{buildroot}%{_datadir}/fish/vendor_completions.d/rgrep.fish
+install -Dm644 _rg %{buildroot}%{_datadir}/zsh/site-functions/_rgrep
+
+%files
+%defattr(-, root, root)
+%doc %{_docdir}/%{name}/
+%{_bindir}/rgrep
+%{_mandir}/man1/rgrep.1.gz*
+%config(noreplace) %{_sysconfdir}/bash_completion.d/rgrep
+%{_datadir}/fish/vendor_completions.d/rgrep.fish
+%{_datadir}/zsh/site-functions/_rgrep
+
+%changelog
