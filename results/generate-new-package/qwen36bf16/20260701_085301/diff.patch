 %prep
+%autosetup -n ripgrep-%{version}
 
 %build
-
-%check
+cargo build --release %__rust_build_flags
 
 %install
-tar xf %{S:0} -C %{buildroot}%{_bindir}/
+# Install the binary
+install -Dpm 0755 target/release/rg %{buildroot}%{_bindir}/rg
+
+# Generate and install man page
+mkdir -p %{buildroot}%{_mandir}/man1
+target/release/rg --man > %{buildroot}%{_mandir}/man1/rg.1 2>/dev/null || true
+
+# Install shell completions
+mkdir -p %{buildroot}%{_sysconfdir}/bash_completion.d
+target/release/rg --completion bash > %{buildroot}%{_sysconfdir}/bash_completion.d/rg 2>/dev/null || true
+
+mkdir -p %{buildroot}%{_datadir}/fish/vendor_completions.d
+target/release/rg --completion fish > %{buildroot}%{_datadir}/fish/vendor_completions.d/rg.fish 2>/dev/null || true
+
+mkdir -p %{buildroot}%{_datadir}/zsh/site-functions
+target/release/rg --completion zsh > %{buildroot}%{_datadir}/zsh/site-functions/_rg 2>/dev/null || true
+
+# Install documentation files
+install -Dpm 0644 COPYING %{buildroot}%{_docdir}/%{name}/COPYING
+install -Dpm 0644 LICENSE-MIT %{buildroot}%{_docdir}/%{name}/LICENSE-MIT
+install -Dpm 0644 UNLICENSE %{buildroot}%{_docdir}/%{name}/UNLICENSE
+install -Dpm 0644 README.md %{buildroot}%{_docdir}/%{name}/README
+install -Dpm 0644 FAQ.md %{buildroot}%{_docdir}/%{name}/FAQ
+install -Dpm 0644 CHANGELOG.md %{buildroot}%{_docdir}/%{name}/CHANGELOG
+
+# Create ripgrep symlink for convenience (rg is the actual binary name)
+ln -sf rg %{buildroot}%{_bindir}/ripgrep
 
 %files
 %{_bindir}/rg
