# AI model configurations for pbuild-ai examples

# Default model to use when no --model is specified
default: "qwen36"

# Define available OpenAI-compatible hosts
hosts:
  local:
    url: "http://localhost:11434"
    name: "Local Ollama"
    description: "Local Ollama instance on default port"
  remote1:
    url: "http://example.com:11434"
    name: "Remote Server 1"
    description: "Example remote Ollama server"

# Model configurations
models:
  gemma4:
    display: "Gemma 4 31B"
    host: "remote1"
    model: "default"
  gemma4_12b:
    display: "Gemma 4 12b QAT 256k"
    host: "local"
    model: "gemma4:12b-qat-256k"
  qwen36:
    display: "Qwen3.6:35B-a3b"
    host: "local"
    model: "qwen3.6:35b-a3b"
  qwen36bf16:
    display: "Qwen3.6:35B-a3b-bf16"
    host: "local"
    model: "qwen3.6:35b-a3b-bf16"
  qwen27:
    display: "Qwen 3.5 27B"
    host: "local"
    model: "qwen3.6:27b"
  ornith35b:
    display: "Ornith 1.0 35B"
    host: "local"
    model: "ornith:35b"
  ornith9b:
    display: "Ornith-1.0:9B"
    host: "local"
    model: "ornith:9b"
  mistral:
    display: "Mistral Medium 2.5 128b Q4"
    host: "local"
    model: "mistral-medium-3.5:128b-q4-256k"
